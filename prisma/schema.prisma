generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Movie {
  id             Int      @id @default(autoincrement())
  title          String   @unique
  duration       Int
  classification String
  synopsis       String   @db.Text
  createdAt      DateTime @default(now())
}

model Sala {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  tipo      String
  capacidad Int
  createdAt DateTime @default(now())
}
